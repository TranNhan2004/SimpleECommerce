{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_DB_CONNECTION_STRING (string)"
  },
  "KeycloakOptions": {
    "Realm": "YOUR_REALM_NAME (string)",
    "AuthServerUrl": "YOUR_KEYCLOAK_SERVER_URL (string)",
    "Resource": "YOUR_BACKEND_AUDIENCE (string)",
    "VerifyTokenAudience": "YOUR_VERIFY_TOKEN_AUDIENCE (bool)",
    "TimeoutSeconds": "YOUR_TIMEOUT_SECONDS (int)"
  },
  "SmtpOptions": {
    "Host": "YOUR_SMTP_HOST (string)",
    "Port": "YOUR_SMTP_PORT (int)",
    "Username": "YOUR_SMTP_USERNAME (string)",
    "Password": "YOUR_SMTP_PASSWORD (string)",
    "UseSsl": "YOUR_SMTP_USE_SSL (bool)",
    "From": "YOUR_SMTP_USERNAME (string)"
  },
  "GlobalRateLimiterOptions": {
    "TokenLimit": 1000,
    "TokensPerPeriod": 1000,
    "ReplenishmentPeriodSeconds": 1,
    "AutoReplenishment": true
  },
  "IpRateLimiterOptions": {
    "TokenLimit": 10,
    "TokensPerPeriod": 1,
    "ReplenishmentPeriodSeconds": 1,
    "AutoReplenishment": true
  },
  "RedisOptions": {
    "ConnectionString": "",
    "InstanceName": "simple-ecommerce:"
  },
  "TranslationOptions": {
    "DefaultLocale": "en",
    "SupportedLocales": [
      "en",
      "vi"
    ],
    "StaticResourcesPath": "ErrorMessages",
    "Provider": "none",
    "CacheDurationHours": 24,
    "UseSourceTextWhenProviderUnavailable": true,
    "OpenAI": {
      "ApiKey": "",
      "Model": "gpt-4.1-mini",
      "Temperature": 0.2,
      "MaxOutputTokenCount": 300,
      "Instructions": "You are a translation engine. Return only the translated text. Preserve the original meaning and keep the response concise."
    },
    "GoogleAI": {
      "ApiKey": "",
      "Model": "gemini-2.0-flash",
      "Temperature": 0.2,
      "MaxOutputTokens": 300,
      "SystemInstruction": "You are a translation engine. Return only the translated text. Preserve the original meaning and keep the response concise."
    }
  }
}
