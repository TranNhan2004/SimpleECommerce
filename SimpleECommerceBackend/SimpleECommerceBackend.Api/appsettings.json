{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_DB_CONNECTION_STRING (string)"
  },
  "KeycloakOptions": {
    "Realm": "YOUR_REALM_NAME (string)",
    "AuthServerUrl": "YOUR_KEYCLOAK_SERVER_URL (string)",
    "Resource": "YOUR_BACKEND_AUDIENCE (string)",
    "VerifyTokenAudience": "YOUR_VERIFY_TOKEN_AUDIENCE (bool)",
    "TimeoutSeconds": "YOUR_TIMEOUT_SECONDS (int)"
  },
  "SmtpOptions": {
    "Host": "YOUR_SMTP_HOST (string)",
    "Port": "YOUR_SMTP_PORT (int)",
    "Username": "YOUR_SMTP_USERNAME (string)",
    "Password": "YOUR_SMTP_PASSWORD (string)",
    "UseSsl": "YOUR_SMTP_USE_SSL (bool)",
    "From": "YOUR_SMTP_USERNAME (string)"
  },
  "GlobalRateLimiterOptions": {
    "TokenLimit": "YOUR_GLOBAL_TOKEN_LIMIT (int)",
    "TokensPerPeriod": "YOUR_GLOBAL_TOKENS_PER_PERIOD (int)",
    "ReplenishmentPeriodSeconds": "YOUR_GLOBAL_REPLENISHMENT_PERIOD_SECONDS (int)",
    "AutoReplenishment": "YOUR_GLOBAL_AUTO_REPLENISHMENT (bool)"
  },
  "IpRateLimiterOptions": {
    "TokenLimit": "YOUR_IP_TOKEN_LIMIT (int)",
    "TokensPerPeriod": "YOUR_IP_TOKENS_PER_PERIOD (int)",
    "ReplenishmentPeriodSeconds": "YOUR_IP_REPLENISHMENT_PERIOD_SECONDS (int)",
    "AutoReplenishment": "YOUR_IP_AUTO_REPLENISHMENT (bool)"
  },
  "RedisOptions": {
    "ConnectionString": "YOUR_REDIS_CONNECTION_STRING (string)",
    "InstanceName": "YOUR_REDIS_INSTANCE_NAME (string)"
  },
  "TranslationOptions": {
    "DefaultLocale": "YOUR_DEFAULT_LOCALE (string)",
    "SupportedLocales": "YOUR_SUPPORT_LOCALES (list<string>)",
    "StaticResourcesPath": "YOUR_STATIC_RESOURCES_PATH (string)",
    "Provider": "YOUR_PROVIDER (string)",
    "CacheDurationHours": "YOUR_CACHE_DURATION_HOURS (int)",
    "UseSourceTextWhenProviderUnavailable": "YOUR_USE_SOURCE_TEXT_WHEN_PROVIDER_UNAVAILABLE (bool)",
    "OpenAI": {
      "ApiKey": "YOUR_OPENAI_API_KEY (string)",
      "Model": "YOUR_OPENAI_MODEL (string)",
      "Temperature": "YOUR_OPENAI_TEMPERATURE (float | double)",
      "MaxOutputTokenCount": "YOUR_OPENAI_MAX_OUTPUT_TOKEN_COUNT (int)",
      "Instructions": "YOUR_OPENAI_INSTRUCTION (string)"
    },
    "GoogleAI": {
      "ApiKey": "YOUR_GOOGLEAI_API_KEY (string)",
      "Model": "YOUR_GOOGLEAI_MODEL (string)",
      "Temperature": "YOUR_GOOGLEAI_TEMPERATURE (float | double)",
      "MaxOutputTokenCount": "YOUR_GOOGLEAI_MAX_OUTPUT_TOKEN_COUNT (int)",
      "Instructions": "YOUR_GOOGLEAI_INSTRUCTION (string)"
    }
  }
}
