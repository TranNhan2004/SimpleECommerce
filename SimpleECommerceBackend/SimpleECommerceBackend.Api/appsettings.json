{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_DB_CONNECTION_STRING (string)"
  },
  "Keycloak": {
    "realm": "YOUR_REALM_NAME (string)",
    "auth-server-url": "YOUR_KEYCLOAK_SERVER_URL (string)",
    "ssl-required": "YOUR_SSL_REQUIRED (string)",
    "resource": "YOUR_CLIENT_ID (string)",
    "credentials": {
      "secret": "YOUR_CLIENT_SECRET (string)"
    },
    "confidential-port": "YOUR_CONFIDENTIAL_PORT (int)",
    "verify-token-audience": "YOUR_VERIFY_TOKEN_AUDIENCE (bool)",
    "token-endpoint": "YOUR_TOKEN_ENDPOINT (string)",
    "userinfo-endpoint": "YOUR_USERINFO_ENDPOINT (string)",
    "introspection-endpoint": "YOUR_INTROSPECTION_ENDPOINT (string)",
    "admin-url": "YOUR_ADMIN_URL (string)",
    "timeout-seconds": "YOUR_TIMEOUT_SECONDS (int)"
  },
  "SmtpOptions": {
    "Host": "YOUR_SMTP_HOST (string)",
    "Port": "YOUR_SMTP_PORT (int)",
    "Username": "YOUR_SMTP_USERNAME (string)",
    "Password": "YOUR_SMTP_PASSWORD (string)",
    "UseSsl": "YOUR_SMTP_USE_SSL (bool)",
    "From": "YOUR_SMTP_USERNAME (string)"
  }
}
