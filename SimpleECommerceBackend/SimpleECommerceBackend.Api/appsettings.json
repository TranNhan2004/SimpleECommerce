{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_DB_CONNECTION_STRING (string)"
  },
  "Keycloak": {
    "Realm": "YOUR_REALM_NAME (string)",
    "AuthServerUrl": "YOUR_KEYCLOAK_SERVER_URL (string)",
    "Resource": "YOUR_BACKEND_AUDIENCE (string)",
    "VerifyTokenAudience": "YOUR_VERIFY_TOKEN_AUDIENCE (bool)",
    "TimeoutSeconds": "YOUR_TIMEOUT_SECONDS (int)"
  },
  "SmtpOptions": {
    "Host": "YOUR_SMTP_HOST (string)",
    "Port": "YOUR_SMTP_PORT (int)",
    "Username": "YOUR_SMTP_USERNAME (string)",
    "Password": "YOUR_SMTP_PASSWORD (string)",
    "UseSsl": "YOUR_SMTP_USE_SSL (bool)",
    "From": "YOUR_SMTP_USERNAME (string)"
  },
  "GlobalRateLimiterOptions": {
    "TokenLimit": 1000,
    "TokensPerPeriod": 1000,
    "ReplenishmentPeriodSeconds": 1,
    "AutoReplenishment": true
  },
  "IpRateLimiterOptions": {
    "TokenLimit": 10,
    "TokensPerPeriod": 1,
    "ReplenishmentPeriodSeconds": 1,
    "AutoReplenishment": true
  },
  "Translation": {
    "DefaultLocale": "en",
    "SupportedLocales": [ "en", "vi" ],
    "StaticResourcesPath": "ErrorMessages",
    "Provider": "none",
    "CacheDurationHours": 24,
    "UseSourceTextWhenProviderUnavailable": true,
    "Redis": {
      "ConnectionString": "",
      "InstanceName": "simple-ecommerce:translations:"
    },
    "OpenAI": {
      "ApiKey": "",
      "Model": "gpt-4.1-mini",
      "BaseUrl": "https://api.openai.com/v1"
    },
    "GoogleAI": {
      "ApiKey": "",
      "Model": "gemini-2.0-flash",
      "BaseUrl": "https://generativelanguage.googleapis.com/v1beta"
    }
  }
}
