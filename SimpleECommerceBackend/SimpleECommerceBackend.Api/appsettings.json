{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_DB_CONNECTION_STRING (str)"
  },
  "JwtSettings": {
    "Secret": "YOUR_JWT_SECRET (str)",
    "Issuer": "YOUR_JWT_ISSUER (str)",
    "Audience": "YOUR_JWT_AUDIENCE (str)",
    "AccessTokenExpirationMinutes": "YOUR_REFRESH_TOKEN_EXPIRATION (int)",
    "RefreshTokenExpirationMinutes": "YOUR_ACCESS_TOKEN_EXPIRATION (int)",
    "AccountVerificationTokenExpirationMinutes": "YOUR_ACCOUNT_VERIFICATION_EXPIRATION (int)",
    "PasswordResetTokenExpirationMinutes": "YOUR_VERIFICATION_EXPIRATION (int)"
  },
  "SmtpOptions": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "YOUR_SMTP_USERNAME (str)",
    "Password": "YOUR_SMTP_PASSWORD (str)",
    "UseSsl": "YOUR_SMTP_USE_SSL (bool)",
    "From": "YOUR_SMTP_USERNAME (str)"
  }
}
