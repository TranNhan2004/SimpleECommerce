{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": ["http://localhost:4200"]
  },
  "Auth": {
    "FrontendBaseUrl": "http://localhost:4200",
    "PostLoginRedirectPath": "/",
    "PostLogoutRedirectPath": "/login",
    "SessionCookieName": "APP_SESSION_ID",
    "CsrfCookieName": "XSRF-TOKEN",
    "CsrfHeaderName": "X-CSRF-TOKEN",
    "SessionExpireMinutes": 60,
    "OAuthStateExpireMinutes": 10,
    "CookieSecure": false,
    "CookieSameSite": "Lax"
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/my-realm",
    "BaseUrl": "http://localhost:8080",
    "Realm": "my-realm",
    "ClientId": "my-web-bff",
    "ClientSecret": "CHANGE_ME",
    "AuthorizationEndpoint": "http://localhost:8080/realms/my-realm/protocol/openid-connect/auth",
    "TokenEndpoint": "http://localhost:8080/realms/my-realm/protocol/openid-connect/token",
    "UserInfoEndpoint": "http://localhost:8080/realms/my-realm/protocol/openid-connect/userinfo",
    "EndSessionEndpoint": "http://localhost:8080/realms/my-realm/protocol/openid-connect/logout",
    "CallbackPath": "/auth/login/callback",
    "RedirectUri": "http://localhost:5000/auth/login/callback",
    "Scopes": ["openid", "profile", "email"]
  },
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_DB_CONNECTION_STRING (string)"
  },
  "SmtpOptions": {
    "Host": "YOUR_SMTP_HOST (string)",
    "Port": "YOUR_SMTP_PORT (int)",
    "Username": "YOUR_SMTP_USERNAME (string)",
    "Password": "YOUR_SMTP_PASSWORD (string)",
    "UseSsl": "YOUR_SMTP_USE_SSL (bool)",
    "From": "YOUR_SMTP_USERNAME (string)"
  },
  "GlobalRateLimiterOptions": {
    "TokenLimit": "YOUR_GLOBAL_TOKEN_LIMIT (int)",
    "TokensPerPeriod": "YOUR_GLOBAL_TOKENS_PER_PERIOD (int)",
    "ReplenishmentPeriodSeconds": "YOUR_GLOBAL_REPLENISHMENT_PERIOD_SECONDS (int)",
    "AutoReplenishment": "YOUR_GLOBAL_AUTO_REPLENISHMENT (bool)"
  },
  "IpRateLimiterOptions": {
    "TokenLimit": "YOUR_IP_TOKEN_LIMIT (int)",
    "TokensPerPeriod": "YOUR_IP_TOKENS_PER_PERIOD (int)",
    "ReplenishmentPeriodSeconds": "YOUR_IP_REPLENISHMENT_PERIOD_SECONDS (int)",
    "AutoReplenishment": "YOUR_IP_AUTO_REPLENISHMENT (bool)"
  },
  "RedisOptions": {
    "ConnectionString": "YOUR_REDIS_CONNECTION_STRING (string)",
    "InstanceName": "YOUR_REDIS_INSTANCE_NAME (string)",
    "PrefixKeyLimits": {
      "YOUR_PREFIX_KEY (string)": "YOUR_REDIS_PREFIX_KEY_LIMIT (int)"
    }
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "simple-ecommerce-api",
    "ServiceVersion": "1.0.0",
    "PrometheusScrapeEndpointPath": "/metrics"
  },
  "TranslationOptions": {
    "DefaultLocale": "YOUR_DEFAULT_LOCALE (string)",
    "SupportedLocales": "YOUR_SUPPORT_LOCALES (list<string>)",
    "StaticResourcesPath": "YOUR_STATIC_RESOURCES_PATH (string)",
    "Provider": "YOUR_PROVIDER (string)",
    "CacheDurationHours": "YOUR_CACHE_DURATION_HOURS (int)",
    "UseSourceTextWhenProviderUnavailable": "YOUR_USE_SOURCE_TEXT_WHEN_PROVIDER_UNAVAILABLE (bool)",
    "OpenAI": {
      "ApiKey": "YOUR_OPENAI_API_KEY (string)",
      "Model": "YOUR_OPENAI_MODEL (string)",
      "Temperature": "YOUR_OPENAI_TEMPERATURE (float | double)",
      "MaxOutputTokenCount": "YOUR_OPENAI_MAX_OUTPUT_TOKEN_COUNT (int)",
      "Instructions": "YOUR_OPENAI_INSTRUCTION (string)"
    },
    "GoogleAI": {
      "ApiKey": "YOUR_GOOGLEAI_API_KEY (string)",
      "Model": "YOUR_GOOGLEAI_MODEL (string)",
      "Temperature": "YOUR_GOOGLEAI_TEMPERATURE (float | double)",
      "MaxOutputTokenCount": "YOUR_GOOGLEAI_MAX_OUTPUT_TOKEN_COUNT (int)",
      "Instructions": "YOUR_GOOGLEAI_INSTRUCTION (string)"
    }
  },
  "HardDeleteOptions": {
    "DaysUntilHardDelete": "YOUR_DAYS_UNTIL_HARD_DELETE (int)"
  }
}
